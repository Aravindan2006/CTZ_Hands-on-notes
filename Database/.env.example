# Copy this file to .env and fill in your own values.

# Which relational DB to target: postgresql | mysql
DB_ENGINE=postgresql

DB_HOST=localhost
DB_PORT=5432
DB_NAME=college_db_orm
DB_USER=postgres
DB_PASSWORD=change_me

# SQLAlchemy connection pool tuning
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Set to True to log every SQL statement (used to detect N+1 queries)
DB_ECHO=False

# MongoDB (Hands-On 5)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=college_nosql
